# Server configuration
PORT=5001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# Database configuration
# Replace with your actual PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/workmesh?schema=public"

# JWT Secrets
JWT_ACCESS_SECRET=your_jwt_access_secret_key_change_me_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me_in_production

# SMTP configuration for verification and password reset emails
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="WorkMesh HR <no-reply@workmesh.com>"
